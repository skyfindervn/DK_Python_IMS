# ============================================================
# DK Python IMS — Web API config
# ============================================================
# Sao chép file này thành .env và điền giá trị thực

# Địa chỉ server (localhost khi dev, IP thực khi deploy)
API_HOST=0.0.0.0
API_PORT=2342

# Môi trường: development | production
ENV=development

# (Tùy chọn) Secret key để Laravel xác thực request
API_SECRET_KEY=

# Scale pixel/mm cho OpenCV (2=96DPI, 3=144DPI)
SCALE_PX_PER_MM=2.0

# Logging level: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
